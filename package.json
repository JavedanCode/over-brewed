{
  "name": "over-brewed",
  "version": "1.0.0",
  "description": "Over Brewed | 2D Computer Graphics Game",
  "main": "index.js",
  "scripts": {
    "format": "prettier src --write",
    "formatCheck": "prettier src --check",
    "lint": "eslint src",
    "start": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "test": "jest",
    "watch": "jest --watch *.js",
    "watchAll": "jest --watchAll",
    "deploy": "gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JavedanCode/over-brewed.git"
  },
  "keywords": [],
  "contributors": ["Soren Javedan", "Majid Shahani"],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JavedanCode/over-brewed/issues"
  },
  "homepage": "https://github.com/JavedanCode/over-brewed",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "clean-webpack-plugin": "^1.0.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "file-loader": "^6.2.0",
    "gh-pages": "^6.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
}
